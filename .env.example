# ============================================================
# PubSub PWA — Environment Variables
# ============================================================
# Salin file ini menjadi .env lalu isi nilainya:
#   cp .env.example .env
#
# JANGAN commit file .env ke repository!
# Semua variabel wajib diawali VITE_ agar dapat dibaca oleh Vite.
# ============================================================

# ── Appwrite ─────────────────────────────────────────────────
# Endpoint Appwrite (Cloud atau self-hosted)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Project ID — Appwrite Console → Settings → Project ID
VITE_APPWRITE_PROJECT_ID=your_project_id

# Database ID (sesuai init.cjs)
VITE_APPWRITE_DATABASE_ID=pubsub_db

# Collection IDs
VITE_APPWRITE_COL_TOPICS=topics
VITE_APPWRITE_COL_EVENTS=events
VITE_APPWRITE_COL_SUBSCRIPTIONS=subscriptions

# Function IDs
VITE_APPWRITE_FN_PUBLISH=publish-event
VITE_APPWRITE_FN_NOVU_SUBSCRIBE=novu-subscribe

# ── Novu ─────────────────────────────────────────────────────
# Application Identifier — BUKAN secret API key
# Novu Dashboard → Settings → API Keys → Application Identifier
VITE_NOVU_APP_ID=your_novu_application_identifier

# Web Push (VAPID) — generate dengan: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_APPWRITE_FN_PUSH_SUBSCRIBE=push-subscribe
